# LLM Provider Configuration: 'nvidia' or 'openai'
LLM_PROVIDER=nvidia

# NVIDIA API Key (if LLM_PROVIDER is 'nvidia')
# Use the OpenAI compatible base URL: https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=

# OpenAI API Key (if LLM_PROVIDER is 'openai')
OPENAI_API_KEY=

# Model to use:
# E.g. meta/llama-3.1-70b-instruct for NVIDIA
# E.g. gpt-4o-mini for OpenAI
LLM_MODEL=meta/llama-3.1-70b-instruct

# Search Config (Optional: If Tavily is desired, otherwise falls back to DuckDuckGo)
TAVILY_API_KEY=

# Server Settings
PORT=8000
HOST=0.0.0.0
